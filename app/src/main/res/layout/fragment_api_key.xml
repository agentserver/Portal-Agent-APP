<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg_secondary">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@drawable/bg_section_header"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="API Key 管理"
            android:textColor="@color/app_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/key_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 个"
            android:textColor="@color/app_text_muted"
            android:textSize="12sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/key_provider_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:background="@color/app_bg_secondary">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_key_provider_claude"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Claude"
            android:textSize="13sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_key_provider_codex"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Codex"
            android:textSize="13sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/key_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/provider_config_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="12dp"
                app:cardBackgroundColor="@color/app_card_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/app_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/provider_config_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CLI 配置"
                        android:textColor="@color/app_text_primary"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <EditText
                        android:id="@+id/provider_model_edit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Model（可选）"
                        android:paddingStart="12dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="10dp"
                        android:singleLine="true"
                        android:textColor="@color/app_text_primary"
                        android:textColorHint="@color/app_text_hint"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/provider_config_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:textColor="@color/app_text_muted"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_apply_provider_config"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="应用配置"
                            android:textColor="@color/app_accent"
                            android:textSize="13sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@color/app_card_bg"
                            app:strokeColor="@color/app_accent"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_edit_raw_provider_config"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="原始配置"
                            android:textColor="@color/app_primary"
                            android:textSize="13sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@color/app_card_bg"
                            app:strokeColor="@color/app_primary"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Key 列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/key_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/app_bg_secondary"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

        </LinearLayout>

    </ScrollView>

    <!-- 底部：添加按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/app_bg_secondary"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_key"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="+ 添加 Key"
            android:textSize="14sp"
            android:textColor="@color/app_accent"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/app_card_bg"
            app:strokeColor="@color/app_accent"
            app:strokeWidth="1dp" />

    </LinearLayout>

</LinearLayout>

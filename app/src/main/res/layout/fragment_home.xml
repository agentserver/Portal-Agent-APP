<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── 主内容区 ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- 状态栏 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 历史记录按钮（≡） -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_history"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:text="≡"
                    android:textSize="20sp"
                    android:textColor="#555555"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />

                <TextView
                    android:id="@+id/home_session_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:maxLines="1"
                    android:paddingTop="6dp"
                    android:paddingEnd="120dp"
                    android:paddingBottom="6dp"
                    android:text="Claude Code"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_home_settings"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="@string/action_open_settings"
                    android:text="⚙"
                    android:textColor="#555555"
                    android:textSize="18sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/home_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:clickable="false"
                android:focusable="false"
                android:text="● 等待中"
                android:textColor="#888888"
                android:textSize="12sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="#E0E0E0" />

        </FrameLayout>

        <!-- 聊天消息列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chat_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            android:scrollbars="vertical" />

        <!-- 底部操作区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <!-- 快捷操作按钮行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_stop_claude"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="打断"
                    android:textSize="12sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:backgroundTint="#F44336"
                    android:textColor="@android:color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_new_session"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="新建对话"
                    android:textSize="12sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:backgroundTint="#2196F3"
                    android:textColor="@android:color/white" />

            </LinearLayout>

            <!-- 无障碍权限行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/accessibility_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="● 无障碍: 未启用"
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_accessibility"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="开启无障碍"
                    android:textSize="12sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="#BDBDBD" />

            </LinearLayout>

            <!-- 截图权限行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/screen_capture_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="● 截图: 未授权"
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_screen_capture"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="授权截图"
                    android:textSize="12sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="#BDBDBD" />

            </LinearLayout>

            <!-- 附件预览条（选中文件后显示） -->
            <LinearLayout
                android:id="@+id/attachment_preview_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FFF9C4"
                android:paddingStart="10dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/attachment_name_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="#5D4037"
                    android:maxLines="1"
                    android:ellipsize="middle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_attachment"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="×"
                    android:textSize="16sp"
                    android:textColor="#795548"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />

            </LinearLayout>

            <!-- 输入行：📎 + 文本框 + ⏎ + 发送 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_attach_file"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="4dp"
                    android:text="📎"
                    android:textSize="16sp"
                    android:textColor="#757575"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    app:strokeColor="#BDBDBD" />

                <EditText
                    android:id="@+id/home_input_edit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="输入消息..."
                    android:textColor="#212121"
                    android:textColorHint="#AAAAAA"
                    android:background="#EEEEEE"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:imeOptions="actionNone"
                    android:maxLines="4"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_enter"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="4dp"
                    android:text="⏎"
                    android:textColor="#757575"
                    android:textSize="16sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    app:strokeColor="#BDBDBD" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/home_send_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="发送"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#1976D2"
                    android:textSize="13sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── 左侧抽屉：历史 / 记忆 / 技能 ─────────────────────────────────── -->
    <LinearLayout
        android:layout_width="288dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FAFAFA"
        android:elevation="8dp">

        <!-- Tab 栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F0F0F0">

            <TextView
                android:id="@+id/tab_history"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="历史"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1976D2"
                android:background="#FFFFFF" />

            <TextView
                android:id="@+id/tab_memory"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="记忆"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#888888"
                android:background="#F0F0F0" />

            <TextView
                android:id="@+id/tab_skills"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="技能"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#888888"
                android:background="#F0F0F0" />

            <TextView
                android:id="@+id/tab_agent_task"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="任务"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#888888"
                android:background="#F0F0F0" />

            <TextView
                android:id="@+id/tab_uploads"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="上传"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#888888"
                android:background="#F0F0F0" />

        </LinearLayout>

        <!-- 面板切换器 -->
        <ViewFlipper
            android:id="@+id/drawer_flipper"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- ── 面板 0：历史对话 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/session_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="vertical" />

                <TextView
                    android:id="@+id/session_empty_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无历史记录\n完成一次对话后自动保存"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ── 面板 1：记忆库 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- 标题行 + 刷新 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="记忆库"
                        android:textSize="13sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/btn_memory_refresh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔄"
                        android:textSize="16sp"
                        android:padding="8dp" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/memory_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="vertical" />

                <TextView
                    android:id="@+id/memory_empty_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="记忆库为空"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ── 面板 2：技能 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- 标题行 + 新建 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="技能 (Slash Commands)"
                        android:textSize="13sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/btn_skill_add"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="＋"
                        android:textSize="18sp"
                        android:textColor="#1976D2"
                        android:padding="8dp" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/skills_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="vertical" />

                <TextView
                    android:id="@+id/skills_empty_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无技能\n点击 ＋ 新建"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ── 面板 3：AgentServer 任务 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AgentServer 任务"
                        android:textSize="13sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/btn_agent_task_clear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="清空"
                        android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:padding="8dp" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/agent_task_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="vertical" />

                <TextView
                    android:id="@+id/agent_task_empty_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="尚无任务记录\nAgentServer 下发任务后自动显示"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="visible" />

            </LinearLayout>

            <!-- ── 面板 4：上传文件 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="上传文件"
                        android:textSize="13sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/btn_uploads_clear_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="清空全部"
                        android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:padding="8dp" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/upload_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="vertical" />

                <TextView
                    android:id="@+id/upload_empty_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无上传文件"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="visible" />

            </LinearLayout>

        </ViewFlipper>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:padding="14dp">

    <!-- 第一行：别名 + 激活标记 + 删除按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/key_alias"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/app_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/key_active_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 当前"
            android:textColor="@color/app_success"
            android:textSize="12sp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete_key"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:text="删除"
            android:textColor="@color/app_warning"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/app_card_bg"
            app:strokeColor="@color/app_warning"
            app:strokeWidth="1dp" />

    </LinearLayout>

    <!-- 第二行：脱敏 Key 值 -->
    <TextView
        android:id="@+id/key_masked"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/app_text_muted"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:singleLine="true"
        android:ellipsize="end" />

    <!-- 第三行：设为当前按钮（激活时隐藏） -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_set_active"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="10dp"
        android:text="设为当前"
        android:textColor="@color/app_accent"
        android:textSize="12sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@color/app_card_bg"
        app:strokeColor="@color/app_accent"
        app:strokeWidth="1dp" />

</LinearLayout>

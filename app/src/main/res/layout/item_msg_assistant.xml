<?xml version="1.0" encoding="utf-8"?>
<!-- Claude 回复：左对齐深灰气泡 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="56dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/msg_sender_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Claude"
            android:textColor="#777777"
            android:textSize="11sp"
            android:paddingStart="4dp"
            android:paddingBottom="2dp" />

        <!-- 思考过程折叠栏（有 thinking 内容时显示） -->
        <LinearLayout
            android:id="@+id/thinking_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bubble_thinking"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <!-- 点击展开/折叠的标题行 -->
            <TextView
                android:id="@+id/thinking_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="💭 思考过程 ▶"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="italic" />

            <!-- 展开后显示的思考全文 -->
            <TextView
                android:id="@+id/thinking_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:textColor="#999999"
                android:textSize="12sp"
                android:textStyle="italic"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.3"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/msg_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bubble_assistant"
            android:textColor="#212121"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.3" />

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#F5F5F5"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Loom"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/loom_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 未检查"
            android:textColor="#888888"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#E0E0E0" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/loom_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="#F8F8F8"
                android:padding="10dp"
                android:text="Loom 使用共享 Ubuntu 环境，按角色生成配置并启动本机服务。"
                android:textColor="#555555"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/loom_provider_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:text="当前助手：Claude Code"
                android:textColor="#666666"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="本机角色"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/loom_role_mode"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Observer URL"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/loom_observer_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:hint="http://127.0.0.1:8090"
                android:inputType="textUri"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Workspace ID"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/loom_workspace_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:hint="ws-phone"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Workspace API Key"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/loom_workspace_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:hint="Observer bootstrap key"
                android:inputType="textPassword"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="AgentServer URL"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/loom_agentserver_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:hint="https://agent.cs.ac.cn"
                android:inputType="textUri"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Observer 名称"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/loom_observer_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:hint="observer-phone"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Driver 名称"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/loom_driver_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:hint="driver-phone"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Slave 名称"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/loom_slave_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:hint="slave-phone"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Slave 标签"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/loom_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:hint="android,phone,aarch64"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_loom_save"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#1976D2"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="保存"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_loom_status"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="刷新状态"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    app:strokeColor="#BDBDBD" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_loom_setup"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#388E3C"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="生成配置"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_loom_start_observer"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="启动 Observer"
                    android:textColor="#1976D2"
                    android:textSize="13sp"
                    app:strokeColor="#1976D2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_loom_stop_observer"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="停止 Observer"
                    android:textColor="#F57C00"
                    android:textSize="13sp"
                    app:strokeColor="#F57C00" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_loom_register_driver"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="注册 Driver"
                android:textColor="#1976D2"
                android:textSize="13sp"
                app:strokeColor="#1976D2" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_loom_start_slave"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="启动 Slave"
                    android:textColor="#1976D2"
                    android:textSize="13sp"
                    app:strokeColor="#1976D2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_loom_stop_slave"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="停止 Slave"
                    android:textColor="#F57C00"
                    android:textSize="13sp"
                    app:strokeColor="#F57C00" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="8dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/loom_log_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="执行日志"
                android:textColor="#888888"
                android:textSize="11sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_loom_monitor"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"
                android:text="实时监控"
                android:textColor="#1976D2"
                android:textSize="11sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_loom_clear_log"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="0dp"
                android:text="清空"
                android:textColor="#AAAAAA"
                android:textSize="11sp" />

        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <ScrollView
                android:id="@+id/loom_log_scroll"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/loom_log"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#333333"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp" />

            </ScrollView>

        </HorizontalScrollView>

    </LinearLayout>

</LinearLayout>

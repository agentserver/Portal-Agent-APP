<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- 状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#F5F5F5"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AgentServer"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/agentserver_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 检查中"
            android:textColor="#888888"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#E0E0E0" />

    </LinearLayout>

    <!-- 配置 + 操作按钮（可滚动区） -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 连接信息摘要 -->
            <TextView
                android:id="@+id/agentserver_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="#F8F8F8"
                android:padding="10dp"
                android:text="正在检查 AgentServer 状态..."
                android:textColor="#555555"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/agentserver_provider_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:text="当前助手：Claude Code"
                android:textColor="#666666"
                android:textSize="12sp" />

            <!-- 服务器地址 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="服务器地址"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/agentserver_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:hint="https://your-server"
                android:inputType="textUri"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <!-- 注册码 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="沙盒 ID（可选）"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/agentserver_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#EEEEEE"
                android:hint="留空自动复用上次沙盒，或填入指定沙盒 ID"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <!-- 设备名称 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="设备名称（可选）"
                android:textColor="#212121"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/agentserver_device_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="#EEEEEE"
                android:hint="留空则使用主机名，显示在 Web UI 沙盒列表"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:singleLine="true"
                android:textColor="#212121"
                android:textColorHint="#AAAAAA" />

            <!-- 提示文字 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="连接后手机出现为 Web UI 的「本地沙盒」，浏览器可直接使用手机 Claude Code"
                android:textColor="#888888"
                android:textSize="12sp" />

            <!-- 连接 / 断开连接 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_agentserver_connect"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#1976D2"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="连接"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_agentserver_stop"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="断开连接"
                    android:textColor="#F57C00"
                    android:textSize="13sp"
                    app:strokeColor="#F57C00" />

            </LinearLayout>

            <!-- 刷新状态 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_agentserver_refresh"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="刷新状态"
                android:textColor="#555555"
                android:textSize="13sp"
                app:strokeColor="#BDBDBD" />

        </LinearLayout>

    </ScrollView>

    <!-- 执行日志 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="8dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/agentserver_log_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="执行日志"
                android:textColor="#888888"
                android:textSize="11sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_agentserver_monitor"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"
                android:text="实时监控"
                android:textColor="#1976D2"
                android:textSize="11sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_agentserver_clear_log"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="0dp"
                android:text="清空"
                android:textColor="#AAAAAA"
                android:textSize="11sp" />

        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <ScrollView
                android:id="@+id/agentserver_log_scroll"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/agentserver_log"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#333333"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp" />

            </ScrollView>

        </HorizontalScrollView>

    </LinearLayout>

</LinearLayout>

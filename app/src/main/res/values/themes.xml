<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
     https://material.io/develop/android/theming/dark
    -->

    <!-- TermuxApp Light DarkActionBar theme. -->
    <style name="Theme.TermuxApp.Light.DarkActionBar" parent="Theme.BaseActivity.Light.DarkActionBar"/>
    <!-- TermuxApp Light NoActionBar theme. -->
    <style name="Theme.TermuxApp.Light.NoActionBar" parent="Theme.BaseActivity.Light.NoActionBar"/>

    <!-- TermuxApp DayNight DarkActionBar theme. -->
    <style name="Theme.TermuxApp.DayNight.DarkActionBar" parent="Theme.BaseActivity.DayNight.DarkActionBar"/>
    <!-- TermuxApp DayNight NoActionBar theme. -->
    <style name="Theme.TermuxApp.DayNight.NoActionBar" parent="Theme.BaseActivity.DayNight.NoActionBar"/>

    <style name="Theme.ClaudeSettings.Light.NoActionBar" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/app_primary</item>
        <item name="colorPrimaryVariant">@color/app_primary</item>
        <item name="colorPrimaryDark">@color/app_card_bg</item>
        <item name="colorSecondary">@color/app_primary</item>
        <item name="colorOnPrimary">@color/app_text_primary</item>
        <item name="colorAccent">@color/app_primary</item>
        <item name="colorControlNormal">@color/app_text_secondary</item>
        <item name="colorControlActivated">@color/app_primary</item>
        <item name="android:colorAccent">@color/app_primary</item>
        <item name="android:windowBackground">@color/app_bg_secondary</item>
        <item name="android:navigationBarColor">@color/app_card_bg</item>
        <item name="android:statusBarColor">@color/app_bg_secondary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:textColorPrimary">@color/app_text_primary</item>
        <item name="android:textColorSecondary">@color/app_text_secondary</item>
        <item name="android:textColorLink">@color/app_primary</item>
        <item name="android:fontFamily">sans</item>
        <item name="preferenceTheme">@style/ThemeOverlay.ClaudeSettings.Preference</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.MaterialComponents.MaterialAlertDialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.MaterialComponents.MaterialAlertDialog</item>
    </style>

    <style name="ThemeOverlay.ClaudeSettings.Preference" parent="@style/PreferenceThemeOverlay">
        <item name="android:textColorPrimary">@color/app_text_primary</item>
        <item name="android:textColorSecondary">@color/app_text_secondary</item>
        <item name="android:textColorTertiary">@color/app_text_muted</item>
        <item name="android:windowBackground">@color/app_bg_secondary</item>
        <item name="colorAccent">@color/app_primary</item>
        <item name="android:colorAccent">@color/app_primary</item>
        <item name="preferenceStyle">@style/Widget.ClaudeSettings.Preference</item>
        <item name="preferenceScreenStyle">@style/Widget.ClaudeSettings.Preference</item>
        <item name="preferenceCategoryStyle">@style/Widget.ClaudeSettings.PreferenceCategory</item>
        <item name="dialogPreferenceStyle">@style/Widget.ClaudeSettings.DialogPreference</item>
        <item name="dropdownPreferenceStyle">@style/Widget.ClaudeSettings.DropDownPreference</item>
        <item name="switchPreferenceCompatStyle">@style/Widget.ClaudeSettings.SwitchPreferenceCompat</item>
        <item name="seekBarPreferenceStyle">@style/Widget.ClaudeSettings.SeekBarPreference</item>
        <item name="preferenceCategoryTitleTextColor">@color/app_primary</item>
    </style>

    <style name="Widget.ClaudeSettings.Preference" parent="@style/Preference.Material">
        <item name="layout">@layout/preference_settings_item</item>
        <item name="android:layout">@layout/preference_settings_item</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="singleLineTitle">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Widget.ClaudeSettings.PreferenceCategory" parent="@style/Preference.Category.Material">
        <item name="layout">@layout/preference_settings_category</item>
        <item name="android:layout">@layout/preference_settings_category</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Widget.ClaudeSettings.DialogPreference" parent="@style/Preference.DialogPreference.Material">
        <item name="layout">@layout/preference_settings_item</item>
        <item name="android:layout">@layout/preference_settings_item</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="singleLineTitle">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Widget.ClaudeSettings.DropDownPreference" parent="@style/Preference.DropDown.Material">
        <item name="layout">@layout/preference_settings_item</item>
        <item name="android:layout">@layout/preference_settings_item</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="singleLineTitle">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Widget.ClaudeSettings.SwitchPreferenceCompat" parent="@style/Preference.SwitchPreferenceCompat.Material">
        <item name="layout">@layout/preference_settings_item</item>
        <item name="android:layout">@layout/preference_settings_item</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="singleLineTitle">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Widget.ClaudeSettings.SeekBarPreference" parent="@style/Preference.SeekBarPreference.Material">
        <item name="layout">@layout/preference_settings_item</item>
        <item name="android:layout">@layout/preference_settings_item</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>


    <!-- TermuxActivity DayNight NoActionBar theme. -->
    <style name="Theme.TermuxActivity.DayNight.NoActionBar" parent="Theme.TermuxApp.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="android:windowSplashScreenBackground">@color/portalagent_splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/portalagent_splash_background</item>

        <item name="android:windowBackground">@color/black</item>

        <!-- Avoid action mode toolbar pushing down terminal content when
             selecting text on pre-6.0 (non-floating toolbar). -->
        <item name="android:windowActionModeOverlay">true</item>

        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>

        <!-- https://developer.android.com/training/tv/start/start.html#transition-color -->
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>

        <!-- Left drawer. -->
        <item name="buttonBarButtonStyle">@style/TermuxActivity.Drawer.ButtonBarStyle.Light</item>
        <item name="termuxActivityDrawerBackground">@color/white</item>
        <item name="termuxActivityDrawerImageTint">@color/black</item>
        <item name="preferenceTheme">@style/ThemeOverlay.ClaudeSettings.Preference</item>

        <!-- Extra keys colors. -->
        <item name="extraKeysButtonTextColor">@color/white</item>
        <item name="extraKeysButtonActiveTextColor">@color/red_400</item>
        <item name="extraKeysButtonBackgroundColor">@color/black</item>
        <item name="extraKeysButtonActiveBackgroundColor">@color/grey_500</item>
    </style>

</resources>
